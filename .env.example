# =========================
# Polymarket
# =========================

# Приватный ключ кошелька
PRIVATE_KEY=

# Адрес кошелька
WALLET_ADDRESS=


# =========================
# Telegram
# =========================

# Токен Telegram-бота от @BotFather
TELEGRAM_BOT_TOKEN=

# ID чата, куда отправлять уведомления
TELEGRAM_CHAT_ID=


# =========================
# Trading Settings
# =========================

# Размер одной позиции в USDC
POSITION_SIZE=25

# Максимальное количество открытых сделок
MAX_OPEN_TRADES=3

# Стоп-лосс (5%)
STOP_LOSS=0.05

# Тейк-профит (10%)
TAKE_PROFIT=0.10


# =========================
# Bot Settings
# =========================

# Интервал проверки рынка в секундах
LOOP_DELAY=15
